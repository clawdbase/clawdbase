# ==========================================
# clawdbase Configuration
# ==========================================

# Coinbase Advanced Trade API (Required)
# Get credentials at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here

# Environment
# Set to 'false' for LIVE trading with real money
COINBASE_SANDBOX=true

# ==========================================
# Logging
# ==========================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ==========================================
# Trading Configuration
# ==========================================

# Trading pairs (comma-separated)
TRADING_PAIRS=BTC-USD,ETH-USD

# Check interval in milliseconds
TRADING_INTERVAL_MS=60000

# Strategy: dca | momentum | meanreversion
STRATEGY=dca

# ==========================================
# DCA Strategy Settings
# ==========================================

# Amount to buy per interval (USD)
DCA_AMOUNT_USD=10

# Interval between purchases (hours)
DCA_INTERVAL_HOURS=24

# ==========================================
# Risk Management
# ==========================================

# Maximum position size as percent of portfolio
MAX_POSITION_PERCENT=0.1

# Stop loss percentage (0.05 = 5%)
STOP_LOSS_PERCENT=0.05

# Maximum daily loss before stopping (0.1 = 10%)
MAX_DAILY_LOSS_PERCENT=0.1

# ==========================================
# Clawd AI Integration (Optional)
# ==========================================

# Enable AI-powered trade signals
CLAWD_ENABLED=false

# Clawd API key (required if enabled)
CLAWD_API_KEY=

# Minimum confidence threshold for AI signals (0-1)
CLAWD_CONFIDENCE_THRESHOLD=0.75

# ==========================================
# UI Settings
# ==========================================

# Enable terminal UI (set to false for headless)
UI_ENABLED=true

# Refresh interval for UI (milliseconds)
UI_REFRESH_MS=1000
